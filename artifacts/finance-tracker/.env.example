# ──────────────────────────────────────────────────────────────────────────────
# Capacitor / Android Studio build variables
# Copy this file to .env.local and fill in real values before running:
#   pnpm --filter @workspace/finance-tracker run build
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the deployed API server.
# Required for Capacitor (native Android/iOS) builds.
# Leave blank for normal Replit dev/preview — the shared proxy handles routing.
# Example: https://your-app-name.replit.app
VITE_API_BASE_URL=

# Vite dev-server port (Replit injects this automatically; set manually if building locally).
PORT=5173

# URL base path for the web artifact (Replit injects this automatically).
# For Capacitor builds this should be "/" so assets load from the root.
BASE_PATH=/
